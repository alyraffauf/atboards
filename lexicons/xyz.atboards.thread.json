          "title",
          "body",
          "createdAt"
        ],
        "properties": {
          "board": {
            "type": "string",
            "format": "at-uri"
          },
          "title": {
            "type": "string",
            "maxLength": 300
          },
          "body": {
            "type": "string",
            "maxLength": 10000
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
